# Clé API Ollama Cloud (OBLIGATOIRE)
OLLAMA_API_KEY=

# URL de base pour Ollama Cloud
OLLAMA_BASE_URL=https://ollama.com/api

# Modèle à utiliser
OLLAMA_MODEL=qwen3.5

# Timeout Ollama (40s pour réponses LLM)
OLLAMA_TIMEOUT=40

# Timeout Gunicorn (120s pour éviter worker timeout)
GUNICORN_TIMEOUT=120

# Configuration Flask
FLASK_PORT=5000
FLASK_DEBUG=false

# Base de données (Render PostgreSQL)
DATABASE_URL=
